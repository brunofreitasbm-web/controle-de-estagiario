rules_version = '2';

// ============================================================
// Regras de segurança do Firestore — Porto Terapia
// Controle de frequência de estagiários (2 unidades)
// ============================================================
//
// Como aplicar:
// 1. Console do Firebase -> Firestore Database -> aba "Regras" (Rules)
// 2. Cole este conteúdo e clique em "Publicar" (Publish)
//
// O caminho COMPARTILHADO (public/data) permite que todos os
// dispositivos (celular de cada estagiário) leiam a mesma lista de
// estagiários e gravem/vejam os mesmos registros de ponto.
// Exige apenas que o usuário esteja autenticado (login anônimo já basta).

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Dados compartilhados da aplicação (estagiários, frequências, config) ---
    match /artifacts/{appId}/public/data/{document=**} {
      allow read, write: if request.auth != null;
    }

    // --- Dados privados por usuário (compatibilidade com a versão antiga) ---
    match /artifacts/{appId}/users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
